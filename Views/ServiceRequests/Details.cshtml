@model PROG7311_POE.Models.ServiceRequest
@{
    ViewData["Title"] = "Service Request Details";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-glass btn-sm">? Back</a>
    <h1 class="page-title mb-0">Request <span>#@Model.Id</span></h1>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="glass-card">
            <h5 style="color:var(--text-muted);font-size:.75rem;letter-spacing:1px;text-transform:uppercase;">Request Details</h5>
            <div class="section-divider"></div>
            <div class="detail-row"><span class="detail-label">Client</span><span class="detail-value">@Model.Contract?.Client?.Name</span></div>
            <div class="detail-row">
                <span class="detail-label">Contract</span>
                <span class="detail-value">
                    <a asp-controller="Contracts" asp-action="Details" asp-route-id="@Model.ContractId">Contract #@Model.ContractId</a>
                </span>
            </div>
            <div class="detail-row"><span class="detail-label">Description</span><span class="detail-value">@Model.Description</span></div>
            <div class="detail-row"><span class="detail-label">Cost (USD)</span><span class="detail-value">$@Model.Cost.ToString("N2")</span></div>
            <div class="detail-row">
                <span class="detail-label">Local Cost (ZAR)</span>
                <span class="detail-value" style="color:var(--success);font-weight:700">R @Model.LocalCost.ToString("N2")</span>
            </div>
            <div class="detail-row"><span class="detail-label">Status</span><span class="detail-value"><span class="status-badge badge-draft">@(Model.Status ?? "Pending")</span></span></div>
        </div>
        <div class="mt-3 d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-accent">Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
        </div>
    </div>
</div>
