@model IEnumerable<PROG7311_POE.Models.ServiceRequest>
@{
    ViewData["Title"] = "Service Requests";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="page-title mb-0"><i class="bi bi-clipboard-check me-2"></i>Service <span>Requests</span></h1>
    <a asp-action="Create" class="btn btn-accent"><i class="bi bi-plus-circle me-1"></i>New Request</a>
</div>

<div class="glass-card p-0 overflow-hidden">
    <table class="glms-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Client</th>
                <th>Contract</th>
                <th>Description</th>
                <th>Cost (USD)</th>
                <th>Local (ZAR)</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sr in Model)
            {
                <tr>
                    <td style="color:var(--text-muted)">#@sr.Id</td>
                    <td><strong>@sr.Contract?.Client?.Name</strong></td>
                    <td style="color:var(--text-muted)">#@sr.ContractId</td>
                    <td>@sr.Description</td>
                    <td>$@sr.Cost.ToString("N2")</td>
                    <td style="color:var(--success)">R @sr.LocalCost.ToString("N2")</td>
                    <td><span class="status-badge badge-draft">@(sr.Status ?? "Pending")</span></td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@sr.Id" class="btn btn-glass btn-sm me-1"><i class="bi bi-eye"></i></a>
                        <a asp-action="Edit" asp-route-id="@sr.Id" class="btn btn-outline-accent btn-sm me-1"><i class="bi bi-pencil"></i></a>
                        <a asp-action="Delete" asp-route-id="@sr.Id" class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="8" class="text-center py-4" style="color:var(--text-muted)">No service requests found. <a asp-action="Create">Add one</a>.</td></tr>
            }
        </tbody>
    </table>
</div>
