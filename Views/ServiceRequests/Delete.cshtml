@model PROG7311_POE.Models.ServiceRequest
@{
    ViewData["Title"] = "Delete Service Request";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-glass btn-sm">? Back</a>
    <h1 class="page-title mb-0" style="color:var(--danger);">Delete <span>Request</span></h1>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="glass-card" style="border-color:rgba(255,71,87,.3)">
            <p style="color:var(--text-muted)">Are you sure you want to delete this service request?</p>
            <div class="section-divider"></div>
            <div class="detail-row"><span class="detail-label">Contract</span><span class="detail-value">#@Model.ContractId</span></div>
            <div class="detail-row"><span class="detail-label">Description</span><span class="detail-value">@Model.Description</span></div>
            <div class="detail-row"><span class="detail-label">Cost (USD)</span><span class="detail-value">$@Model.Cost.ToString("N2")</span></div>
            <div class="detail-row"><span class="detail-label">Local (ZAR)</span><span class="detail-value" style="color:var(--success)">R @Model.LocalCost.ToString("N2")</span></div>
            <div class="section-divider"></div>
            <form asp-action="Delete" method="post" class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-danger">Yes, Delete</button>
                <a asp-action="Index" class="btn btn-glass">Cancel</a>
            </form>
        </div>
    </div>
</div>
