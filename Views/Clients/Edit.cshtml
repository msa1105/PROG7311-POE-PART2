@model PROG7311_POE.Models.Client
@{
    ViewData["Title"] = "Edit Client";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-glass btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
    <h1 class="page-title mb-0">Edit <span>Client</span></h1>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="glass-card">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Region" class="form-label"></label>
                    <input asp-for="Region" class="form-control" />
                    <span asp-validation-for="Region"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="ContactDetails" class="form-label"></label>
                    <textarea asp-for="ContactDetails" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="ContactDetails"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-accent">Save Changes</button>
                    <a asp-action="Index" class="btn btn-glass">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
