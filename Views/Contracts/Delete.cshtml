@model PROG7311_POE.Models.Contract
@{
    ViewData["Title"] = "Delete Contract";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-glass btn-sm">? Back</a>
    <h1 class="page-title mb-0" style="color:var(--danger);">Delete <span>Contract</span></h1>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="glass-card" style="border-color:rgba(255,71,87,.3)">
            <p style="color:var(--text-muted)">Are you sure you want to delete this contract? All associated service requests will also be removed.</p>
            <div class="section-divider"></div>
            <div class="detail-row"><span class="detail-label">Client</span><span class="detail-value">@Model.Client?.Name</span></div>
            <div class="detail-row"><span class="detail-label">Start Date</span><span class="detail-value">@Model.StartDate.ToString("yy/MM/dd")</span></div>
            <div class="detail-row"><span class="detail-label">End Date</span><span class="detail-value">@Model.EndDate.ToString("yy/MM/dd")</span></div>
            <div class="detail-row">
                <span class="detail-label">Status</span>
                <span class="detail-value"><span class="status-badge badge-@Model.Status.ToString().ToLower()">@Model.Status</span></span>
            </div>
            <div class="section-divider"></div>
            <form asp-action="Delete" method="post" class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-danger">Yes, Delete</button>
                <a asp-action="Index" class="btn btn-glass">Cancel</a>
            </form>
        </div>
    </div>
</div>
